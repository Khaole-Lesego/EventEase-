@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";

    var eventsJson = System.Text.Json.JsonSerializer.Serialize(
        ((List<EventEase.Models.Event>)ViewBag.Events)
            .Select(e => new { eventID = e.EventID, eventName = e.EventName, imageUrl = e.ImageUrl }));

    var venuesJson = System.Text.Json.JsonSerializer.Serialize(
        ((List<EventEase.Models.Venue>)ViewBag.Venues)
            .Select(v => new { venueID = v.VenueID, venueName = v.VenueName, imageUrl = v.ImageUrl }));
}

<section class="entity-page">
    <header class="entity-header">
        <p class="module-kicker">Reservation Atelier</p>
        <h1>Edit Booking</h1>
        <p>Adjust reservation details while maintaining scheduling integrity.</p>
    </header>

    <div class="entity-card">
        <form asp-action="Edit" class="elite-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BookingID" />

            <div class="form-group">
                <label asp-for="EventID" class="control-label"></label>
                <select asp-for="EventID" class="form-control" id="eventSelect" asp-items="ViewBag.EventID"></select>
                <span asp-validation-for="EventID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="VenueID" class="control-label"></label>
                <select asp-for="VenueID" class="form-control" id="venueSelect" asp-items="ViewBag.VenueID"></select>
                <span asp-validation-for="VenueID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="BookingDate" class="control-label"></label>
                <input asp-for="BookingDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="BookingDate" class="text-danger"></span>
            </div>

            <div class="form-group" id="imageChoiceGroup">
                <label class="control-label">Booking Image</label>
                <p style="font-size:0.85rem; color:#aaa;">
                    Choose which image to display on this booking card.
                </p>
                <div id="imageChoiceOptions" style="display:flex; gap:1.5rem; flex-wrap:wrap; margin-bottom:0.75rem;">
                    <span style="color:#aaa; font-size:0.85rem;">Loading options…</span>
                </div>
                <input type="hidden" asp-for="ImageChoice" id="imageChoiceInput" />
                <div id="imagePreview" style="margin-top:0.75rem;"></div>
            </div>

            <div class="entity-actions">
                <button type="submit" class="elite-btn elite-btn--gold">Save Changes</button>
                <a asp-action="Index" class="elite-btn elite-btn--ghost">Back to Bookings</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const events      = @Html.Raw(eventsJson);
        const venues      = @Html.Raw(venuesJson);
        const savedChoice = '@Html.Raw(Model.ImageChoice ?? "")';

        const eventSelect = document.getElementById('eventSelect');
        const venueSelect = document.getElementById('venueSelect');
        const choiceDiv   = document.getElementById('imageChoiceOptions');
        const hiddenInput = document.getElementById('imageChoiceInput');
        const previewDiv  = document.getElementById('imagePreview');

        function updateChoices() {
            const eId = parseInt(eventSelect.value);
            const vId = parseInt(venueSelect.value);
            const ev  = events.find(x => x.eventID === eId);
            const ve  = venues.find(x => x.venueID === vId);

            const options = [];
            if (ev && ev.imageUrl) options.push({ label: 'Event Image (' + ev.eventName + ')', value: 'event', url: ev.imageUrl });
            if (ve && ve.imageUrl) options.push({ label: 'Venue Image (' + ve.venueName + ')', value: 'venue', url: ve.imageUrl });

            choiceDiv.innerHTML = '';
            previewDiv.innerHTML = '';
            hiddenInput.value = '';

            if (options.length === 0) {
                choiceDiv.innerHTML = '<span style="color:#aaa;font-size:0.85rem;">Neither the selected event nor venue has an uploaded image.</span>';
                return;
            }

            options.forEach((opt, idx) => {
                const lbl = document.createElement('label');
                lbl.style.cssText = 'display:flex;align-items:center;gap:0.5rem;cursor:pointer;';

                const radio = document.createElement('input');
                radio.type  = 'radio';
                radio.name  = 'imageChoiceRadio';
                radio.value = opt.value;

                const shouldCheck = (savedChoice === opt.value) || (!savedChoice && idx === 0);
                if (shouldCheck) {
                    radio.checked = true;
                    hiddenInput.value = opt.value;
                    showPreview(opt.url);
                }
                radio.addEventListener('change', () => {
                    hiddenInput.value = opt.value;
                    showPreview(opt.url);
                });

                lbl.appendChild(radio);
                lbl.appendChild(document.createTextNode(opt.label));
                choiceDiv.appendChild(lbl);
            });
        }

        function showPreview(url) {
            previewDiv.innerHTML = url
                ? '<img src="' + url + '" alt="Preview" style="max-height:160px;border:1px solid var(--elite-gold);border-radius:4px;" />'
                : '';
        }

        eventSelect.addEventListener('change', updateChoices);
        venueSelect.addEventListener('change', updateChoices);

        // Populate on page load using the already-selected event/venue
        updateChoices();
    </script>
}