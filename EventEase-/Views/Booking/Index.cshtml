@model IEnumerable<EventEase.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
    var bookings = Model?.ToList() ?? new List<EventEase.Models.Booking>();
    var gallery = new[]
    {
        Url.Content("~/images/bookings/booking-1.svg"),
        Url.Content("~/images/bookings/booking-2.svg"),
        Url.Content("~/images/bookings/booking-3.svg")
    };
}

<section class="elite-module" data-slider-root>
    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"] as string))
    {
        <div class="elite-alert" role="alert">@TempData["ErrorMessage"]</div>
    }

    <div class="module-header">
        <p class="module-kicker">Reservation Ledger</p>
        <h1>Luxury Bookings</h1>
    </div>



    <div class="search-container" style="display:flex; justify-content:center; gap:.5rem; margin-bottom:1.5rem; flex-wrap:wrap;">
        <form asp-action="Index" method="get" style="display:flex; gap:0.5rem; flex-wrap:wrap; justify-content:center;">
            <input type="text" name="searchString" class="form-control"
                   placeholder="Search by Booking ID, event, venue, or YYYY-MM-DD..."
                   value="@ViewBag.SearchString"
                   style="width: 300px; background: rgba(0,0,0,0.6); border-color: var(--elite-gold); color: white;" />
            <button type="submit" class="elite-btn">Search</button>
            <a asp-action="Index" class="elite-btn elite-btn--ghost">Clear</a>
        </form>
        <a asp-controller="Booking" asp-action="List" class="elite-btn elite-btn--gold">Open Full List View</a>
    </div>

    <div class="carousel" data-carousel>
        <div class="list" data-carousel-list>
            @if (bookings.Any())
            {
                for (var i = 0; i < bookings.Count; i++)
                {
                    var item = bookings[i];
                    string image;
                    if (item.ImageChoice == "event" && !string.IsNullOrEmpty(item.Event?.ImageUrl))
                        image = item.Event.ImageUrl;
                    else if (item.ImageChoice == "venue" && !string.IsNullOrEmpty(item.Venue?.ImageUrl))
                        image = item.Venue.ImageUrl;
                    else
                        image = gallery[i % gallery.Length];
                    <article class="item">
                        <img src="@image" alt="Booking backdrop for booking #@item.BookingID" loading="lazy" />
                        <div class="content">
                            <div class="author">EventEase Booking</div>
                            <div class="title">Booking #@item.BookingID</div>
                            <div class="topic">@(item.Event?.EventName ?? "Signature Event")</div>
                            <div class="des">
                                Venue: @(item.Venue?.VenueName ?? "Unassigned") •
                                From @item.StartDate.ToString("dd MMM yyyy HH:mm")
                                to @item.EndDate.ToString("dd MMM yyyy HH:mm")
                            </div>
                            <div class="buttons">
                                <a asp-action="Edit" asp-route-id="@item.BookingID" class="elite-action">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.BookingID" class="elite-action elite-action--ghost">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.BookingID" class="elite-action elite-action--danger">Delete</a>
                                <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <article class="item">
                    <img src="@gallery[0]" alt="Elegant reservation desk" loading="lazy" />
                    <div class="content">
                        <div class="author">EventEase Booking</div>
                        <div class="title">No Bookings Yet</div>
                        <div class="topic">Reserve with Precision</div>
                        <div class="des">Create your first reservation to coordinate venues and events with seamless confidence.</div>
                        <div class="buttons">
                            <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (bookings.Any())
        {
            <div class="thumbnail" data-carousel-thumbnail>
                @for (var i = 0; i < bookings.Count; i++)
                {
                    var item = bookings[i];
                    string image;
                    if (item.ImageChoice == "event" && !string.IsNullOrEmpty(item.Event?.ImageUrl))
                        image = item.Event.ImageUrl;
                    else if (item.ImageChoice == "venue" && !string.IsNullOrEmpty(item.Venue?.ImageUrl))
                        image = item.Venue.ImageUrl;
                    else
                        image = gallery[i % gallery.Length];
                    <div class="item">
                        <img src="@image" alt="Thumbnail for booking #@item.BookingID" loading="lazy" />
                        <div class="content">
                            <div class="title">Booking #@item.BookingID</div>
                        </div>
                    </div>
                }
            </div>

            <div class="arrows">
                <button type="button" class="carousel-btn" data-carousel-prev aria-label="Previous booking">&lt;</button>
                <button type="button" class="carousel-btn" data-carousel-next aria-label="Next booking">&gt;</button>
            </div>
            <div class="time" data-carousel-time></div>
        }
    </div>
</section>