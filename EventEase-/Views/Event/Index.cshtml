@model IEnumerable<EventEase.Models.Event>
@{
    ViewData["Title"] = "Events";
    var events = Model?.ToList() ?? new List<EventEase.Models.Event>();
    var gallery = new[]
    {
        Url.Content("~/images/events/event-1.svg"),
        Url.Content("~/images/events/event-2.svg"),
        Url.Content("~/images/events/event-3.svg")
    };
}

<section class="elite-module" data-slider-root>
    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"] as string))
    {
        <div class="elite-alert" role="alert">@TempData["ErrorMessage"]</div>
    }

    <div class="module-header">
        <p class="module-kicker">Event Collection</p>
        <h1>Signature Events</h1>
    </div>


    <div class="search-container" style="display:flex; justify-content:center; gap:.5rem; margin-bottom:1.5rem; flex-wrap:wrap;">
        <form asp-action="Index" method="get" style="display:flex; gap:0.5rem; flex-wrap:wrap; justify-content:center;">
            <input type="text" name="searchString" class="form-control"
                   placeholder="Search by ID, name, or description..."
                   value="@ViewBag.SearchString"
                   style="width: 300px; background: rgba(0,0,0,0.6); border-color: var(--elite-gold); color: white;" />
            <button type="submit" class="elite-btn">Search</button>
            <a asp-action="Index" class="elite-btn elite-btn--ghost">Clear</a>
        </form>
        <a asp-controller="Event" asp-action="List" class="elite-btn elite-btn--gold">Open Full List View</a>
    </div>

    <div class="carousel" data-carousel>
        <div class="list" data-carousel-list>
            @if (events.Any())
            {
                for (var i = 0; i < events.Count; i++)
                {
                    var item = events[i];
                    var image = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl : gallery[i % gallery.Length];
                    <article class="item">
                        <img src="@image" alt="Event backdrop for @item.EventName" loading="lazy" />
                        <div class="content">
                            <div class="author">EventEase Event</div>
                            <div class="title">@item.EventName</div>
                            <div class="topic">Curated Program</div>
                            <div class="des">@(string.IsNullOrWhiteSpace(item.Description) ? "A refined event outline ready for elegant execution." : item.Description)</div>
                            <div class="buttons">
                                <a asp-action="Edit" asp-route-id="@item.EventID" class="elite-action">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.EventID" class="elite-action elite-action--ghost">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.EventID" class="elite-action elite-action--danger">Delete</a>
                                <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <article class="item">
                    <img src="@gallery[0]" alt="Elegant event ballroom" loading="lazy" />
                    <div class="content">
                        <div class="author">EventEase Event</div>
                        <div class="title">No Events Yet</div>
                        <div class="topic">Design Your First Program</div>
                        <div class="des">Compose a new signature event and shape unforgettable experiences with tasteful precision.</div>
                        <div class="buttons">
                            <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (events.Any())
        {
            <div class="thumbnail" data-carousel-thumbnail>
                @for (var i = 0; i< events.Count; i++)
                {
                    var item = events[i];
                    var image = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl : gallery[i % gallery.Length];
                    <div class="item">
                        <img src="@image" alt="Thumbnail for @item.EventName" loading="lazy" />
                        <div class="content">
                            <div class="title">@item.EventName</div>
                            
                        </div>
                    </div>
                }
            </div>

            <div class="arrows">
                <button type="button" class="carousel-btn" data-carousel-prev aria-label="Previous event">&lt;</button>
                <button type="button" class="carousel-btn" data-carousel-next aria-label="Next event">&gt;</button>
            </div>
            <div class="time" data-carousel-time></div>
        }
    </div>
</section>
