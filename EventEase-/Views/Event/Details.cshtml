@model EventEase.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<section class="entity-page">
    <header class="entity-header">
        <p class="module-kicker">Event Collection</p>
        <h1>@Model.EventName</h1>
        <p>Review this event profile and narrative details.</p>
    </header>

    <div class="entity-card">
        
        
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div style="margin-bottom: 1.5rem; text-align: center;">
                    <img src="@Model.ImageUrl" alt="Image for @Model.EventName"
                         style="max-height: 260px; border-radius: 6px; border: 1px solid var(--elite-gold);" />
                </div>
            }
        
        
        <dl class="elite-detail-grid">
            <dt>@Html.DisplayNameFor(model => model.EventName)</dt>
            <dd>@Html.DisplayFor(model => model.EventName)</dd>
            <dt>@Html.DisplayNameFor(model => model.Description)</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided yet." : Model.Description)</dd>
        </dl>

        <div class="entity-actions">
            <a asp-action="Edit" asp-route-id="@Model?.EventID" class="elite-btn elite-btn--gold">Edit Event</a>
            <a asp-action="Index" class="elite-btn elite-btn--ghost">Back to Events</a>
        </div>
    </div>
</section>
