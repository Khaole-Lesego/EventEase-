@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Edit Venue";
}

<section class="entity-page">
    <header class="entity-header">
        <p class="module-kicker">Venue Atelier</p>
        <h1>Edit Venue</h1>
        <p>Refine the details of this venue while preserving its signature character.</p>
    </header>

    <div class="entity-card">
        <form asp-action="Edit" enctype="multipart/form-data" class="elite-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="VenueID" />

            <div class="form-group">
                <label asp-for="VenueName" class="control-label"></label>
                <input asp-for="VenueName" class="form-control" />
                <span asp-validation-for="VenueName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Location" class="control-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Capacity" class="control-label"></label>
                <input asp-for="Capacity" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <!-- File input for new image -->
            <div class="form-group">
                <label for="ImageFile" class="control-label">Upload New Image</label>
                <input type="file" name="ImageFile" id="ImageFile" class="form-control" accept="image/*" />
                <span class="text-muted">Leave empty to keep the current image.</span>
            </div>

            <!-- Show current image if it exists -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="form-group">
                    <label class="control-label">Current Image</label>
                    <div>
                        <img src="@Model.ImageUrl" alt="Current venue image" style="max-width: 200px; max-height: 150px;" />
                    </div>
                </div>
            }

            <div class="entity-actions">
                <button type="submit" class="elite-btn elite-btn--gold">Save Changes</button>
                <a asp-action="Index" class="elite-btn elite-btn--ghost">Back to Venues</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}