@model IEnumerable<EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
    var venues = Model?.ToList() ?? new List<EventEase.Models.Venue>();
    var gallery = new[]
    {
        Url.Content("~/images/venues/venue-1.svg"),
        Url.Content("~/images/venues/venue-2.svg"),
        Url.Content("~/images/venues/venue-3.svg")
    };
}

<section class="elite-module" data-slider-root>
    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"] as string))
    {
        <div class="elite-alert" role="alert">@TempData["ErrorMessage"]</div>
    }

    <div class="module-header">
        <p class="module-kicker">Venue Portfolio</p>
        <h1>Exceptional Venues</h1>
    </div>

    <div class="carousel" data-carousel>
        <div class="list" data-carousel-list>
            @if (venues.Any())
            {
                for (var i = 0; i < venues.Count; i++)
                {
                    var item = venues[i];
                    var image = !string.IsNullOrWhiteSpace(item.ImageUrl) ? item.ImageUrl : gallery[i % gallery.Length];
                    <article class="item">
                        <img src="@image" alt="Venue backdrop for @item.VenueName" loading="lazy" />
                        <div class="content">
                            <div class="author">EventEase Venue</div>
                            <div class="title">@item.VenueName</div>
                            <div class="topic">@item.Location</div>
                            <div class="des">Capacity: @item.Capacity guests. Curated settings crafted for meaningful gatherings and elevated experiences.</div>
                            <div class="buttons">
                                <a asp-action="Edit" asp-route-id="@item.VenueID" class="elite-action">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.VenueID" class="elite-action elite-action--ghost">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.VenueID" class="elite-action elite-action--danger">Delete</a>
                                <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <article class="item">
                    <img src="@gallery[0]" alt="Refined venue hall" loading="lazy" />
                    <div class="content">
                        <div class="author">EventEase Venue</div>
                        <div class="title">No Venues Yet</div>
                        <div class="topic">Start Your Collection</div>
                        <div class="des">Begin with your first distinguished venue and let your curated destination list grow with every new creation.</div>
                        <div class="buttons">
                            <a asp-action="Create" class="elite-action elite-action--gold">Create New</a>
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (venues.Any())
        {
            <div class="thumbnail" data-carousel-thumbnail>
                @for (var i = 0; i < venues.Count; i++)
                {
                    var item = venues[i];
                    var image = !string.IsNullOrWhiteSpace(item.ImageUrl) ? item.ImageUrl : gallery[i % gallery.Length];
                    <div class="item">
                        <img src="@image" alt="Thumbnail for @item.VenueName" loading="lazy" />
                        <div class="content">
                            <div class="title">@item.VenueName</div>
                           
                        </div>
                    </div>
                }
            </div>

            <div class="arrows">
                <button type="button" class="carousel-btn" data-carousel-prev aria-label="Previous venue">&lt;</button>
                <button type="button" class="carousel-btn" data-carousel-next aria-label="Next venue">&gt;</button>
            </div>
            <div class="time" data-carousel-time></div>
        }
    </div>
</section>
