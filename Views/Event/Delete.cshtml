@model EventEase.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<section class="entity-page">
    <header class="entity-header">
        <p class="module-kicker">Event Collection</p>
        <h1>Delete Event</h1>
        <p class="text-danger">This action removes the event record permanently.</p>
    </header>

    <div class="entity-card">
        <dl class="elite-detail-grid">
            <dt>@Html.DisplayNameFor(model => model.EventName)</dt>
            <dd>@Html.DisplayFor(model => model.EventName)</dd>
            <dt>@Html.DisplayNameFor(model => model.Description)</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided yet." : Model.Description)</dd>
        </dl>

        <form asp-action="Delete" class="entity-actions">
            <input type="hidden" asp-for="EventID" />
            <button type="submit" class="elite-btn elite-btn--danger">Confirm Delete</button>
            <a asp-action="Index" class="elite-btn elite-btn--ghost">Cancel</a>
        </form>
    </div>
</section>
