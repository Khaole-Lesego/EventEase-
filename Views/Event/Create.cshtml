@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<section class="entity-page">
    <header class="entity-header">
        <p class="module-kicker">Event Atelier</p>
        <h1>Create Event</h1>
        <p>Compose a polished event profile with narrative and purpose.</p>
    </header>

    <div class="entity-card">
        <form asp-action="Create" class="elite-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="EventName" class="control-label"></label>
                <input asp-for="EventName" class="form-control" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="entity-actions">
                <button type="submit" class="elite-btn elite-btn--gold">Create Event</button>
                <a asp-action="Index" class="elite-btn elite-btn--ghost">Back to Events</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
